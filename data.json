    {
      "id": "s07",
      "nome": {
        "it": "Sentiero Rifugio Saletti – dal parcheggio",
        "en": "Saletti Refuge Trail – from the car park"
      },
      "zona": "nord-est",
      "difficolta": "E",
      "distanza_km": 2.75,
      "durata_h": 2,
      "dislivello_m": 164,
      "quota_min_m": 1231,
      "quota_max_m": 1395,
      "lat": 37.83981,
      "lng": 14.98889,
      "stagioni": [
        "mag",
        "giu",
        "lug",
        "ago",
        "set",
        "ott"
      ],
      "descrizione": {
        "it": "Il sentiero si sviluppa lungo un'ampia e comoda pista sterrata (spesso identificata con i sentieri CAI 717 o 718) che sale in modo costante ma mai troppo ripido. Il sentiero intercetta infine la famosa Pista Altomontana e conduce direttamente al Rifugio Saletti, una struttura in pietra vulcanica sempre aperta per il bivacco o l'emergenza.",
        "en": "The path follows a wide, easy dirt track (often marked as CAI trails 717 or 718) that climbs steadily but never too steeply. It eventually intersects the famous Altomontana Trail and leads directly to Rifugio Saletti, a volcanic stone structure that remains open at all times for bivouacking or emergencies."
      },
      "categoria": "Escursionismo",
      "gpx_ufficiale": true,
      "foto": "foto/s07.jpg",
      "gpx": "gpx/s07.gpx"
